<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>New Course Notification</title>
  </head>
  <body>
    <!-- Template in Handlebars (HBS) -->
    <script id='email-template' type='text/x-handlebars-template'>
      <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:600px; margin: 0 auto; background-color:#ffffff;
      font-family: Arial, sans-serif; color:#333333;"> <tr> <td align="center" style="padding: 20px 0; background-color: #007bff;"> <h1 style="color:
      #ffffff; font-size: 24px;">New Course Alert!</h1> </td> </tr> <tr> <td style="padding: 20px;"> <p style="font-size: 16px;">Hi
      {{name}},</p> <p style="font-size: 16px;">We’re excited to announce the launch of a brand-new course that you won’t want to miss:</p> <h2
      style="font-size: 20px; color: #007bff;">{{course.title}}</h2> <p style="font-size: 16px;">{{course.description}}</p> <p style="font-size:
      16px;">Ready to get started? <a href="{{course.link}}" style="color: #007bff; text-decoration: none;">Enroll now</a> and take your skills to the
      next level!</p> </td> </tr> <tr> <td align="center" style="padding: 20px; background-color: #f4f4f4;"> <p style="font-size: 14px; color:
      #777777;">You received this email because you are subscribed to our updates. <br /> If you no longer wish to receive these emails, please <a
      href="{{unsubscribeLink}}" style="color: #007bff; text-decoration: none;">unsubscribe here</a>.</p> </td> </tr> </table>
    </script>
  </body>
</html>