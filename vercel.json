{
  "version": 2,
  "builds": [
    {
      "src": "dist/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.ts"
    }
  ],
  "buildCommand": "npm run build  && npm run prisma:migrate",
  "installCommand": "npm install",
  "outputDirectory": "dist"
}
