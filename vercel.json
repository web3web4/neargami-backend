{
 "version": 2,
 "builds": [
  {
   "src": "src/app.ts",
   "use": "@vercel/node",
   "config": { 
    "includeFiles": ["dist/**", "node_modules/**"]
    ,
      "excludeFiles": [ "prisma/**"] 
      }
  
  }
 ],
 "routes": [
  {
   "src": "/(.*)",
   "dest": "src/app.ts"
  }
 ]
  }