{
 "version": 2,
 "builds": [
  {
   "src": "src/app.ts",
   "use": "@vercel/node",
   "config": { 
    "includeFiles": ["dist/**"]
      ,
     "excludeFiles": [ "prisma/**", "node_modules/**"] 
      }
  
  }
 ],
 "routes": [
  {
   "src": "/(.*)",
   "dest": "src/app.ts"
  }
 ]
  }