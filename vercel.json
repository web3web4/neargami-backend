{
 "version": 2,
 "builds": [
  {
   "src": "dist/server.ts",
   "use": "@vercel/node",
   "config": { 
    "includeFiles": ["dist/**"]
      ,
     "excludeFiles": [ "prisma/**", "node_modules/**"] 
      }
  
  }
 ],
 "routes": [
  {
   "src": "/(.*)",
   "dest": "dist/server.js" 
  }
 ]
  }